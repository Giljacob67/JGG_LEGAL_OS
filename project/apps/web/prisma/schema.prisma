generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  admin
  socio
  advogado
  estagiario
  financeiro
  comercial
}

enum Area {
  bancario
  agrario
  tributario
  trabalhista
  civil
  empresarial
  penal
}

enum ProcessoStatus {
  em_andamento
  suspenso
  arquivado
  encerrado
}

enum Risco {
  alto
  medio
  baixo
}

enum PrazoTipo {
  fatal
  dilacao
  audiencia
  reuniao
  tarefa
}

enum PrazoStatus {
  aberto
  cumprido
  perdido
}

enum DocumentoTipo {
  peticao
  contrato
  extrato
  decisao
  certidao
  parecer
  planilha
  procuracao
  declaracao
  notificacao
  termo
  outro
}

enum DocumentoStatus {
  rascunho
  em_revisao
  aprovado
  protocolado
  arquivado
}

enum HonorarioTipo {
  fixo_mensal
  exito
  hora
  combinado
}

enum FaturaStatus {
  pago
  pendente
  atrasado
  cancelado
}

enum TaskStatus {
  aberta
  em_andamento
  aguardando_terceiro
  concluida
  cancelada
}

enum TaskPriority {
  baixa
  media
  alta
  urgente
}

enum ContactType {
  cliente
  parte_contraria
  advogado
  testemunha
  perito
  juiz
  servidor
  fornecedor
  parceiro
  outro
}

enum IntegrationType {
  google_drive
  google_calendar
  google_gmail
  datajud
}

enum Permission {
  // Dashboard
  dashboard_view

  // Processos
  processo_view
  processo_create
  processo_edit
  processo_delete

  // Clientes
  cliente_view
  cliente_create
  cliente_edit
  cliente_delete

  // Contatos
  contato_view
  contato_create
  contato_edit
  contato_delete

  // Prazos e Tarefas
  prazo_view
  prazo_create
  prazo_edit
  prazo_delete
  tarefa_view
  tarefa_create
  tarefa_edit
  tarefa_delete

  // Documentos
  documento_view
  documento_create
  documento_edit
  documento_delete

  // Financeiro
  financeiro_view
  financeiro_create
  financeiro_edit
  financeiro_delete
  financeiro_admin

  // CRM
  crm_view
  crm_create
  crm_edit
  crm_delete

  // IA
  ia_view
  ia_use
  ia_admin

  // Relatórios
  relatorio_view
  relatorio_create

  // Admin
  admin_users
  admin_roles
  admin_integrations
  admin_settings
  admin_audit

  // Sistema
  sistema_view
  sistema_edit
}

// ============================================================
// MODELS
// ============================================================

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  nome      String
  oab       String?
  phone     String?
  cargo     String?
  role      Role     @default(advogado)
  cor       String?
  avatar    String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // Relations
  permissions UserPermission[]

  processosResponsavel Processo[] @relation("Responsavel")
  processosEquipe      Processo[] @relation("Equipe")
  prazos               Prazo[]
  documentos           Documento[]
  faturas              Fatura[]
  timesheets           Timesheet[]
  integrationAccounts  IntegrationAccount[]
}

model UserPermission {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission
  createdAt  DateTime   @default(now())

  @@unique([userId, permission])
}

model Cliente {
  id        String   @id @default(cuid())
  nome      String
  cpfCnpj   String   @unique
  tipo      String   // PF ou PJ
  email     String?
  telefone  String?
  celular   String?
  whatsapp  String?
  endereco  String?
  cidade    String?
  estado    String?
  cep       String?
  origem    String?  // indicação, site, parceiro, prospecção, etc.
  area      Area?
  status    String   @default("ativo") // lead, prospect, ativo, inativo, ex-cliente
  observacoes String?  @db.Text
  responsavelComercialId String?
  responsavelJuridicoId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // Relations
  processos    Processo[]
  honorarios   ContratoHonorarios[]
  faturas      Fatura[]
  notes        Note[]
  contacts     Contact[]
}

model Contact {
  id        String      @id @default(cuid())
  nome      String
  empresa   String?
  cargo     String?
  email     String?
  telefone  String?
  whatsapp  String?
  tipo      ContactType @default(outro)
  observacoes String?   @db.Text
  clienteId String?
  cliente   Cliente?    @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  deletedAt DateTime?
}

model Processo {
  id              String         @id @default(cuid())
  cnj             String         @unique
  clienteId       String
  cliente         Cliente        @relation(fields: [clienteId], references: [id])
  adverso         String?
  adversoAdv      String?        // advogado da parte contrária
  tribunal        String?
  vara            String?
  comarca         String?
  area            Area
  classe          String?        // classe processual
  assunto         String?        // assunto CNJ
  tipo            String
  status          ProcessoStatus @default(em_andamento)
  risco           Risco          @default(medio)
  valorCausa      Decimal?       @db.Decimal(14, 2)
  valorProvavel   Decimal?       @db.Decimal(14, 2)
  estrategia      String?        @db.Text
  proximosPassos  String?        @db.Text
  responsavelId   String
  responsavel     User           @relation("Responsavel", fields: [responsavelId], references: [id])
  equipe          User[]         @relation("Equipe")
  tese            String?        @db.Text
  tagMataMata     Boolean        @default(false)
  distribuicao    DateTime?
  ultimoAndamento DateTime?
  proximoPrazo    DateTime?
  observacoes     String?        @db.Text
  observacoesConfidenciais String? @db.Text
  etiquetas       String[]       @default([])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  // Relations
  andamentos   Andamento[]
  prazos       Prazo[]
  documentos   Documento[]
  honorarios   ContratoHonorarios[]
  tasks        Task[]
  notes        Note[]
}

model Andamento {
  id         String   @id @default(cuid())
  processoId String
  processo   Processo @relation(fields: [processoId], references: [id], onDelete: Cascade)
  data       DateTime
  evento     String
  descricao  String   @db.Text
  fonte      String   @default("manual") // manual, datajud, pje, esaj, projudi
  critico    Boolean  @default(false)
  createdAt  DateTime @default(now())
  deletedAt  DateTime?
}

model Prazo {
  id            String     @id @default(cuid())
  processoId    String?
  processo      Processo?  @relation(fields: [processoId], references: [id], onDelete: Cascade)
  clienteId     String?
  tipo          PrazoTipo
  titulo        String
  descricao     String?    @db.Text
  vence         DateTime
  prazoInterno  DateTime?
  responsavelId String
  responsavel   User       @relation(fields: [responsavelId], references: [id])
  status        PrazoStatus @default(aberto)
  alertas       Int[]      @default([15, 7, 3, 1])
  notificar     Boolean    @default(true)
  validadoPor   String?    // para prazos sugeridos por IA
  origem        String     @default("manual") // manual, ia, datajud
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  deletedAt     DateTime?
}

model Task {
  id          String      @id @default(cuid())
  titulo      String
  descricao   String?     @db.Text
  processoId  String?
  processo    Processo?   @relation(fields: [processoId], references: [id], onDelete: SetNull)
  clienteId   String?
  responsavelId String?
  prazoFatal  DateTime?
  prazoInterno DateTime?
  prioridade  TaskPriority @default(media)
  status      TaskStatus  @default(aberta)
  checklist   Json?       // array de { done: boolean, text: string }
  recorrente  Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  // Relations
  notes Note[]
}

model Documento {
  id         String         @id @default(cuid())
  processoId String?
  processo   Processo?      @relation(fields: [processoId], references: [id], onDelete: SetNull)
  clienteId  String?
  nome       String
  tipo       DocumentoTipo
  status     DocumentoStatus @default(rascunho)
  versao     Int            @default(1)
  tamanho    Int?
  url        String?        // URL no storage (Google Drive ou local)
  driveFileId String?       // ID do arquivo no Google Drive
  hash       String?
  segredo    Boolean        @default(false)
  autorId    String
  autor      User           @relation(fields: [autorId], references: [id])
  tags       String[]       @default([])
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  deletedAt  DateTime?

  // Relations
  versions DocumentVersion[]
}

model DocumentVersion {
  id          String    @id @default(cuid())
  documentoId String
  documento   Documento @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  versao      Int
  url         String?
  driveFileId String?
  hash        String?
  tamanho     Int?
  autorId     String?
  createdAt   DateTime  @default(now())
}

model JurisprudenciaTrecho {
  id            String @id @default(cuid())
  orgao         String
  identificador String
  ementa        String @db.Text
  trecho        String @db.Text
  ano           Int
  url           String?
  tags          String[]
  relevancia    Float?
  createdAt     DateTime @default(now())
  deletedAt     DateTime?
}

model ContratoHonorarios {
  id           String        @id @default(cuid())
  numero       String?       @unique // número do contrato
  clienteId    String
  cliente      Cliente       @relation(fields: [clienteId], references: [id])
  processoId   String?
  processo     Processo?     @relation(fields: [processoId], references: [id], onDelete: SetNull)
  tipo         HonorarioTipo
  valorFixo    Decimal?      @db.Decimal(14, 2)
  percentual   Decimal?      @db.Decimal(5, 2)
  taxaHora     Decimal?      @db.Decimal(8, 2)
  horasMes     Int?
  estimativa   Decimal?      @db.Decimal(14, 2)
  vigente      Boolean       @default(true)
  dataInicio   DateTime      @default(now())
  dataFim      DateTime?
  observacoes  String?       @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  faturas Fatura[]
}

model Fatura {
  id           String       @id @default(cuid())
  numero       String?      @unique
  clienteId    String
  cliente      Cliente      @relation(fields: [clienteId], references: [id])
  contratoId   String?
  contrato     ContratoHonorarios? @relation(fields: [contratoId], references: [id])
  emitidoPorId String
  emitidoPor   User         @relation(fields: [emitidoPorId], references: [id])
  mes          String
  ano          Int?
  valor        Decimal      @db.Decimal(14, 2)
  desconto     Decimal?     @db.Decimal(14, 2)
  status       FaturaStatus @default(pendente)
  vencimento   DateTime
  pagoEm       DateTime?
  formaPagamento String?
  comprovanteUrl String?
  observacoes  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?
}

model Expense {
  id          String   @id @default(cuid())
  descricao   String
  valor       Decimal  @db.Decimal(14, 2)
  categoria   String?
  centroCusto String?
  processoId  String?
  clienteId   String?
  vencimento  DateTime?
  pagoEm      DateTime?
  formaPagamento String?
  comprovanteUrl String?
  status      String   @default("previsto") // previsto, pago, vencido, cancelado
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
}

model Timesheet {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  processoId String?
  data       DateTime
  horas      Decimal  @db.Decimal(4, 2)
  atividade  String
  faturado   Boolean  @default(false)
  faturaId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?
}

model Note {
  id         String   @id @default(cuid())
  titulo     String?
  conteudo   String   @db.Text
  processoId String?
  processo   Processo? @relation(fields: [processoId], references: [id], onDelete: Cascade)
  clienteId  String?
  cliente    Cliente?  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  taskId     String?
  task       Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  autorId    String
  tipo       String   @default("interna") // interna, confidencial, historico
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?
}

model Tag {
  id        String   @id @default(cuid())
  nome      String   @unique
  cor       String?  @default("#3b82f6")
  createdAt DateTime @default(now())

  relations TagRelation[]
}

model TagRelation {
  id         String @id @default(cuid())
  tagId      String
  tag        Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  entidade   String // "Cliente", "Processo", "Contact", "Documento"
  entidadeId String

  @@unique([tagId, entidade, entidadeId])
  @@index([entidade, entidadeId])
}

model SystemSetting {
  id        String   @id @default(cuid())
  chave     String   @unique
  valor     String   @db.Text
  descricao String?
  updatedAt DateTime @updatedAt
}

model IntegrationAccount {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tipo          IntegrationType
  provider      String          // google, datajud, etc.
  accessToken   String?         @db.Text
  refreshToken  String?         @db.Text
  expiresAt     DateTime?
  scope         String?
  email         String?         // email da conta integrada
  active        Boolean         @default(true)
  lastSyncAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model PromptTemplate {
  id          String   @id @default(cuid())
  nome        String   @unique
  slug        String   @unique
  descricao   String?
  sistema     String   @db.Text
  usuario     String   @db.Text
  categoria   String   @default("geral")
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AIConversation {
  id        String   @id @default(cuid())
  userId    String
  titulo    String?
  contexto  String?  // "processo:123", "cliente:456", "geral"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages AIMessage[]
}

model AIMessage {
  id             String   @id @default(cuid())
  conversaId     String
  conversa       AIConversation @relation(fields: [conversaId], references: [id], onDelete: Cascade)
  role           String   // system, user, assistant
  content        String   @db.Text
  tokensPrompt   Int?
  tokensCompletion Int?
  provider       String?
  model          String?
  createdAt      DateTime @default(now())
}

model AIUsageLog {
  id            String   @id @default(cuid())
  userId        String
  acao          String   // "chat", "resumo", "minuta", "analise"
  modulo        String
  entidade      String?  // "Processo", "Cliente", etc.
  entidadeId    String?
  provider      String
  model         String
  tokensPrompt  Int?
  tokensTotal   Int?
  custoEstimado Decimal? @db.Decimal(10, 6)
  status        String   @default("sucesso") // sucesso, erro, timeout
  createdAt     DateTime @default(now())
}

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  userId     String?
  userEmail  String?
  acao       String
  entidade   String
  entidadeId String
  diff       Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([entidade, entidadeId])
  @@index([createdAt])
  @@index([userId])
}
